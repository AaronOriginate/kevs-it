---
interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface Props {
  columns?: FooterColumn[];
}

const { columns } = Astro.props;

const defaultColumns: FooterColumn[] = columns || [
  {
    title: 'Quick Links',
    links: [
      { label: 'About Kevin', href: '/about' },
      { label: 'Services', href: '/services' },
      { label: 'Reviews', href: '/reviews' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    title: 'Services',
    links: [
      { label: 'TechShield Pro', href: '/techshield-pro' },
      { label: 'Cyber Essentials', href: '/cyber-essentials' },
      { label: 'Cipher Academy', href: 'https://cipher-academy.co.uk' },
      { label: 'Telecoms', href: '/telecoms' },
      { label: 'Hardware Shop', href: '/shop' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Reviews', href: '/reviews' },
      { label: 'Cipher Academy', href: 'https://cipher-academy.co.uk' },
    ],
  },
  {
    title: 'Contact Us',
    links: [
      { label: 'Email Kevin', href: 'mailto:contact@kevsit.co.uk' },
      { label: 'Book a Meeting', href: '/contact' },
      { label: 'WhatsApp', href: 'https://wa.me/441170000000' },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-border-subtle" role="contentinfo">
  <div class="mx-auto max-w-[1320px] px-6 lg:px-10 py-16">
    <div class="grid lg:grid-cols-[1.5fr_1fr_1fr_1fr_1fr] gap-12 lg:gap-8">
      <!-- Logo & tagline -->
      <div>
        <a href="/" class="flex items-center gap-2 text-[14px] uppercase tracking-normal">
          <svg class="w-5 h-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-text-primary">KEVS IT</span>
        </a>
        <p class="mt-4 text-[13px] text-text-secondary leading-[1.5] max-w-xs">
          IT support and cyber security for Bristol businesses with 1&ndash;50 people. 14 years&rsquo; experience. No jargon, no lock-in.
        </p>
        <!-- Social icons -->
        <div class="mt-6 flex items-center gap-4">
          <a
            href="https://x.com/kevsit"
            class="text-text-secondary hover:text-cyan transition-colors duration-200"
            aria-label="Follow us on X"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/kevs-it"
            class="text-text-secondary hover:text-cyan transition-colors duration-200"
            aria-label="Follow us on LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {defaultColumns.map((col) => (
        <div>
          <h3 class="text-[13px] text-text-primary uppercase tracking-wider">
            {col.title}
          </h3>
          <ul class="mt-4 space-y-3" role="list">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[13px] text-text-secondary hover:text-cyan transition-colors duration-200"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-border-subtle">
    <div class="mx-auto max-w-[1320px] px-6 lg:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[12px] text-text-secondary">
        &copy; {currentYear} Kevs IT. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-[12px] text-text-secondary">
        <a href="/privacy" class="hover:text-text-secondary transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-text-secondary transition-colors">Terms</a>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Bristol, UK
        </span>
      </div>
    </div>
  </div>
</footer>
