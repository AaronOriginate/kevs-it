---
import Icon from '../Icon.astro';

interface FeatureCard {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

interface Props {
  cards: FeatureCard[];
}

const { cards } = Astro.props;
---

<!-- Feature strip - overlaps hero with negative margin like Sentrisec -->
<section class="relative z-10 -mt-20" aria-label="Key features" id="services">
  <h2 class="sr-only">Key features</h2>
  <div class="mx-auto max-w-[1320px] px-6 lg:px-10">
    <div class="grid md:grid-cols-3 gap-0">
      {cards.map((card, i) => (
        <article
          class={`bg-card-surface border border-border-subtle p-8 lg:p-10 fade-up stagger-${i + 1} card-hover`}
        >
          <!-- Icon -->
          <div class="mb-5">
            <Icon name={card.icon} class="w-20 h-20" gradient />
          </div>

          <h3 class="text-[16px] uppercase tracking-normal text-text-primary font-normal mb-3">
            {card.title}
          </h3>
          <p class="text-[14px] text-text-secondary leading-[1.4]">
            {card.description}
          </p>
          {card.href && (
            <a
              href={card.href}
              class="inline-flex items-center gap-2 mt-5 text-[13px] text-cyan uppercase tracking-wider hover:brightness-125 transition-all duration-200"
              {...(card.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              Learn more<span class="sr-only"> about {card.title}</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
